{
  "name": "flashcards-open-source-app-backend",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "dev": "npm run bundle --prefix ../../api && tsx watch src/index.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run bundle --prefix ../../api && npm run clean && tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "npm run bundle --prefix ../../api && node scripts/run-tests.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1050.0",
    "@aws-sdk/client-lambda": "^3.1050.0",
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/client-secrets-manager": "^3.1050.0",
    "@hono/node-server": "^2.0.3",
    "@langfuse/openai": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@sentry/aws-serverless": "^10.53.1",
    "aws-jwt-verify": "^5.1.1",
    "hono": "^4.12.21",
    "openai": "^6.38.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sentry/cli": "^3.4.2",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "protobufjs": "^7.5.8"
  },
  "engines": {
    "node": "24.x"
  }
}
